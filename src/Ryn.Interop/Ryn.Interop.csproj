<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Ryn.Interop</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Description>Auto-generated saucer C bindings for Ryn via ClangSharp</Description>
    <PackageTags>ryn;interop;saucer;webview;pinvoke</PackageTags>
    <!-- Generated P/Invoke bindings: suppress analyzers that don't apply -->
    <NoWarn>CA5392;CA1401;CA2101;CA1707;CA1712;IDE0161;IDE0040</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="runtimes/**/*" Pack="true" PackagePath="runtimes" />
    <!-- Pack="false": packaging happens via the None item above (-> runtimes/) + Ryn.Interop.targets.
         This Content item only copies the native libs to output for in-repo project references;
         packing it as content/contentFiles would flag Windows .dll as misplaced assemblies (NU5100). -->
    <Content Include="runtimes/**/*" Pack="false" CopyToOutputDirectory="PreserveNewest" Link="runtimes/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Ryn.Interop.targets" Pack="true" PackagePath="buildTransitive" />
    <None Include="Ryn.Interop.targets" Pack="true" PackagePath="build" />
  </ItemGroup>
</Project>
