<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Ryn.Interop</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Description>Auto-generated saucer C bindings for Ryn via ClangSharp</Description>
    <PackageTags>ryn;interop;saucer;webview;pinvoke</PackageTags>
    <!-- Generated P/Invoke bindings: suppress analyzers that don't apply -->
    <NoWarn>CA5392;CA1401;CA2101;CA1707;CA1712;IDE0161;IDE0040</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- One item that both packs the native libs into runtimes/ AND copies them to output for
         in-repo project references. Using a single None (not a separate Content) avoids two things:
         packing into content/contentFiles, where Windows .dll get rejected as misplaced assemblies
         (NU5100); and a Pack-metadata conflict between overlapping None/Content globs that dropped
         files from the package entirely. -->
    <None Include="runtimes/**/*"
          Pack="true" PackagePath="runtimes/%(RecursiveDir)%(Filename)%(Extension)"
          CopyToOutputDirectory="PreserveNewest"
          Link="runtimes/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Ryn.Interop.targets" Pack="true" PackagePath="buildTransitive" />
    <None Include="Ryn.Interop.targets" Pack="true" PackagePath="build" />
  </ItemGroup>
</Project>
