{
  "capabilities": {
    "devkit": true,
    "fs": {
      "allow": ["readTextFile", "readFile", "writeTextFile", "readDir", "stat", "exists", "mkdir"],
      "scope": ["$APP_DATA"]
    },
    "dialog": true,
    "clipboard": true,
    "shell": {
      "allow": ["execute", "spawn", "kill", "open", "metrics", "pty", "ptyWrite", "ptyResize", "ptyKill", "ptyMetrics"],
      "commands": ["echo", "date", "whoami", "uname", "ls", "pwd"]
    },
    "notification": true
  }
}
